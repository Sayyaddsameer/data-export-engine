# =============================================================================
# Data Export Engine — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=exports_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Full DSN used by the application (constructed from the above in docker-compose)
DATABASE_URL=postgresql://user:password@db:5432/exports_db

# ─── Application ──────────────────────────────────────────────────────────────
PORT=8080

# Number of connections in the asyncpg pool
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10

# Rows fetched per chunk from the database cursor (controls memory usage)
DB_CHUNK_SIZE=1000

# Parquet row-group size (rows buffered per group before flush)
PARQUET_ROW_GROUP_SIZE=50000

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
